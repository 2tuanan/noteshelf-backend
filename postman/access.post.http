@url=http://localhost:4088/api

### ─── AUTH ────────────────────────────────────────────

### 1. Register (run once to create account)
# @name register
POST {{url}}/user-register
Content-Type: application/json

{
    "name": "Test User",
    "email": "test@test.com",
    "password": "test123"
}

###

### 2. Login — httpYac auto-saves the cookie for all requests below
# @name login
POST {{url}}/user-login
Content-Type: application/json

{
    "email": "test@test.com",
    "password": "test123"
}

### ─── NOTES ───────────────────────────────────────────

### 3. Get all notes
# @name getNotes
GET {{url}}/get-notes

###

### 4. Add note (valid)
# @name addNote
POST {{url}}/add-note
Content-Type: application/json

{
    "title": "My first note",
    "content": "This is the note content"
}

###

### 5. Update title only (AC1)
# @name updateNoteTitle
# @ref addNote
PUT {{url}}/update-note/{{addNote.id}}
Content-Type: application/json

{
    "title": "Updated Title"
}

###

### 6. Update content only (AC2)
# @name updateNoteContent
# @ref addNote
PUT {{url}}/update-note/{{addNote.id}}
Content-Type: application/json

{
    "content": "<p>Updated content</p>"
}

###

### 7. Ownership check with second user (AC3)
# @name registerUser2
POST {{url}}/user-register
Content-Type: application/json

{
    "name": "Test User 2",
    "email": "user2@test.com",
    "password": "test123"
}

###

### 8. Login as second user
# @name loginUser2
POST {{url}}/user-login
Content-Type: application/json

{
    "email": "user2@test.com",
    "password": "test123"
}

###

### 9. Update note as second user (expect 403)
# @name updateNoteForbidden
# @ref loginUser2
PUT {{url}}/update-note/{{addNote.id}}
Content-Type: application/json

{
    "title": "Forbidden Update"
}

###

### 10. Non-existent note (AC4)
# @name updateNoteMissing
PUT {{url}}/update-note/507f1f77bcf86cd799439011
Content-Type: application/json

{
    "title": "Missing Note"
}

###

### 11. Empty body blocked (AC5)
# @name updateNoteEmpty
# @ref addNote
PUT {{url}}/update-note/{{addNote.id}}
Content-Type: application/json

{}

###

### 12. Delete note
# @name deleteNote
DELETE {{url}}/delete-note/NOTE_ID

### ─── SECURITY TESTS ──────────────────────────────────

### AC1 — Missing title (expect 400)
# @name ac1_missingTitle
POST {{url}}/add-note
Content-Type: application/json

{
    "content": "No title here"
}

###

### AC2 — Content too long (expect 400)
# @name ac2_contentTooLong
POST {{url}}/add-note
Content-Type: application/json

{
    "title": "Test",
    "content": "{{'x'.repeat(50001)}}"
}

###

### AC3 — Search without q param (expect 400)
# @name ac3_searchNoParam
GET {{url}}/search-notes

###

### AC4 — NoSQL injection on login (expect 400)
# @name ac4_nosqlInjection
POST {{url}}/user-login
Content-Type: application/json

{
    "email": { "$gt": "" },
    "password": "test"
}

###

### AC5 — CastError invalid ID (expect 400 Invalid ID format)
# @name ac5_castError
DELETE {{url}}/delete-note/NOTANOBJECTID

###

### AC6 — Missing email on register (expect 400)
# @name ac6_missingEmail
POST {{url}}/user-register
Content-Type: application/json

{
    "name": "Test",
    "password": "test123"
}

###

### AC7 — Rate limit (run 11 times — expect 429 on 11th)
# @name ac7_rateLimit
POST {{url}}/user-login
Content-Type: application/json

{
    "email": "test@test.com",
    "password": "wrongpassword"
}

### ─── ADMIN ───────────────────────────────────────────

### Admin login (separate session)
# @name adminLogin
POST {{url}}/admin-login
Content-Type: application/json

{
    "email": "admin@gmail.com",
    "password": "admin123"
}

###

### Get all users (admin only)
# @name getAllUsers
GET {{url}}/get-all-users

###

### Delete user (replace USER_ID)
# @name deleteUser
DELETE {{url}}/delete-user/USER_ID